---
/**
 * Upgraded to Figma Embed Kit 2.0: https://developers.figma.com/docs/embeds/embed-kit-2.0/
 * Implemented server side... yasss
 */

interface Props {
  url: string;
  title?: string;
  embedHost?: string;
  theme?: "light" | "dark" | "system";
  footer?: boolean;
  viewportControls?: boolean;
  pageSelector?: boolean;
  mode?: "dev";
  class?: string;
}

const {
  url,
  title = "Figma embed",
  embedHost = "share",
  theme = "dark",
  footer,
  viewportControls,
  pageSelector,
  mode,
  class: className,
} = Astro.props;

function buildEmbedKit2Src(rawUrl: string): string {
  const u = new URL(rawUrl);
  const allowedHosts = new Set([
    "www.figma.com",
    "figma.com",
    "embed.figma.com",
  ]);
  if (!allowedHosts.has(u.hostname)) {
    throw new Error(
      `FigmaEmbed: expected a figma.com URL, got hostname "${u.hostname}"`,
    );
  }
  if (u.hostname !== "embed.figma.com") {
    u.hostname = "embed.figma.com";
  }

  u.searchParams.set("embed-host", embedHost);

  if (theme) u.searchParams.set("theme", theme);
  if (footer !== undefined) u.searchParams.set("footer", String(footer));
  if (viewportControls !== undefined) {
    u.searchParams.set("viewport-controls", String(viewportControls));
  }
  if (pageSelector !== undefined) {
    u.searchParams.set("page-selector", String(pageSelector));
  }
  if (mode) u.searchParams.set("mode", mode);

  return u.toString();
}

const embedSrc = buildEmbedKit2Src(url);
---

<div
  class:list={[
    "not-prose relative mb-8 mt-4 aspect-video w-full max-w-full overflow-hidden rounded-lg border border-white/10 bg-black/20 shadow-lg",
    className,
  ]}
>
  <iframe
    src={embedSrc}
    title={title}
    loading="lazy"
    allowfullscreen
    allow="clipboard-read; clipboard-write; fullscreen"
    class="absolute inset-0 h-full w-full border-0"></iframe>
</div>
