---
type PaddingSize = "sm" | "md" | "lg";

interface Props {
  padding?: PaddingSize;
  class?: string;
}

const { padding = "md", class: className = "" } = Astro.props;

const paddingClass =
  padding === "sm" ? "!p-3" : padding === "lg" ? "!p-6" : "!p-4";
---

<div
  class:list={[
    "mb-6 border-l-2 border-[#454545] bg-[var(--card-color)]",
    paddingClass,
    className,
  ]}
>
  <slot />
</div>
