---
import Layout from "../layouts/Layout.astro";
import BackLink from "../components/BackLink.astro";
import WordpressFetcher from "../components/editorial/WordpressFetcher.tsx";
import LocalFetcher from "../components/editorial/LocalFetcher.tsx";
import Footer from "../layouts/Footer.astro";
---

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: auto;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: left;
    margin: 2rem;
  }
</style>

<Layout title="Other Work - Liam Sullivan">
  <div class="content">
    <BackLink label={"Back"} href="/" />
    <h1 class="my-20 text-5xl font-bold">Other Work</h1>
    <div class="mx-auto mb-16 flex flex-col">
      <p class="text-md mb-2 font-bold uppercase">Layouts</p>
      <LocalFetcher category={"layouts"} maxCols={2} client:load />
    </div>
    <div class="mx-auto mb-16 flex flex-col">
      <p class="text-md mb-2 font-bold uppercase">Graphic Design</p>
      <LocalFetcher category={"graphic-design"} client:load />
    </div>
    <div class="mx-auto mb-16 flex flex-col">
      <p class="text-md mb-2 font-bold uppercase">Design Club</p>
      <LocalFetcher category={"presentations"} client:load />
    </div>
    <div class="mx-auto flex flex-col pb-28">
      <p class="text-md mb-2 font-bold uppercase">Cooking</p>
      <LocalFetcher category={"cooking"} client:load />
    </div>
    <div class="mx-auto flex flex-col pb-28">
      <p class="text-md mb-2 font-bold uppercase">Berlin</p>
      <WordpressFetcher client:load />
    </div>
  </div>
  <Footer />
</Layout>
