---
interface Props {
  variant?: "default" | "wiki" | "row";
  class?: string;
}

const { variant = "default", class: className = "" } = Astro.props;
---

<div
  class:list={[
    "case-study-card-grid",
    variant === "wiki" && "case-study-card-grid--wiki",
    variant === "row" && "case-study-card-grid--row",
    className,
  ]}
>
  <slot />
</div>

<style is:global>
  .case-study-card-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17.5rem), 1fr));
  }

  .case-study-card {
    background-color: var(--card-color);
    border: 1px solid #333;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 0;
    width: 100%;
    min-width: 0;
  }

  .case-study-card__icon-wrap {
    display: flex;
    justify-content: center;
    margin: 0.5rem 0 0.75rem;
  }

  .case-study-card__icon-wrap--prominent {
    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  .case-study-card__icon-svg {
    display: block;
    flex-shrink: 0;
  }

  .case-study-card__title {
    margin-bottom: 0.5rem;
  }

  .case-study-card__body :global(p) {
    margin: 0;
  }

  .case-study-card-grid--wiki {
    margin: 0 auto 0.75rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 500px) and (max-width: 768px) {
    .case-study-card-grid--wiki {
      grid-template-columns: repeat(2, 1fr);
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 769px) {
    .case-study-card-grid--wiki {
      grid-template-columns: repeat(6, 1fr);
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(1) {
      grid-column: 1 / 3;
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(2) {
      grid-column: 3 / 5;
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(3) {
      grid-column: 5 / 7;
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(4) {
      grid-column: 1 / 4;
    }

    .case-study-card-grid--wiki .case-study-card:nth-child(5) {
      grid-column: 4 / 7;
    }
  }

  .case-study-card-grid--wiki .case-study-card {
    margin-bottom: 0;
  }

  .case-study-card-grid--wiki .case-study-card__icon-wrap .case-study-card__icon-svg {
    height: 7rem;
    width: 7rem;
    margin: 1rem auto 2rem;
  }

  .case-study-card-grid--wiki .case-study-card__title {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    line-height: 1.35;
    font-weight: 500;
    color: #fff;
  }

  .case-study-card-grid--wiki .case-study-card__body {
    font-size: 0.875rem;
    line-height: 1.625;
    color: #a1a1aa;
  }

  .case-study-card-grid--row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
    grid-template-columns: unset;
  }

  .case-study-card--row {
    padding: 1rem;
    margin-bottom: 0;
  }

  .case-study-card--row .case-study-card__row {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    align-items: stretch;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .case-study-card--row .case-study-card__row {
      flex-direction: column;
    }
  }

  .case-study-card--row .case-study-card__icon-wrap--row {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    margin: 0;
  }

  .case-study-card--row .case-study-card__icon-wrap--row .case-study-card__icon-svg {
    width: 8rem;
    height: 8rem;
  }

  .case-study-card--row .case-study-card__row-main {
    margin-block: auto;
    min-width: 0;
    flex: 1;
  }

  .case-study-card--row .case-study-card__title {
    margin-bottom: 0.25rem;
  }
</style>
